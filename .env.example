# GCP Configuration
# Paste the full contents of your service account JSON key here (minified to one line)
GOOGLE_CLOUD_CREDENTIALS={"type":"service_account",...}

# Your GCP project ID
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# GCS bucket names (defaults shown)
GCS_RAW_BUCKET=sytycai-video-transcripts
GCS_ENRICHED_BUCKET=sytycai-video-transcripts-enriched

# Server port (Heroku sets this automatically)
PORT=3000
