# ─── GCP AUTHENTICATION ──────────────────────────────────────────────────
# Used by both the local Node.js ingestion app and local Cloud Function testing.
# Download a service account key JSON from GCP Console → IAM → Service Accounts
# → Keys → Add Key → Create New (JSON). Set the absolute path here.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# ─── GCP PROJECT ─────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# ─── GCS BUCKETS ─────────────────────────────────────────────────────────
# Used by the Node.js app (raw only) and the Cloud Function (reads raw, writes enriched).
GCS_RAW_BUCKET=sytycai-video-transcripts
GCS_ENRICHED_BUCKET=sytycai-video-transcripts-enriched

# ─── CLOUD FUNCTION — CLAUDE API ─────────────────────────────────────────
# Required when running the Python enrichment function locally via functions-framework.
# In deployed production, this is sourced from GCP Secret Manager — not from .env.
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── ELEVENLABS (Playback Room) ──────────────────────────────────────────
# Used by the local Node.js app's /playback page to read confessionals aloud.
# Sign up at elevenlabs.io → Profile → API key.
ELEVENLABS_API_KEY=sk_...
# Voice ID — defaults to "Carolina" (female voice). Browse voices
# at elevenlabs.io/voice-library to audition alternatives.
ELEVENLABS_VOICE_ID=VCUa8W1mPO0QcgrSewvs
# Male voice — used for husbands, Andy Cohen, and other male cast members.
# Defaults to "Min Diesel" if unset. Browse alternatives at elevenlabs.io/voice-library.
ELEVENLABS_MALE_VOICE_ID=q3pCVYOxlOb5G3l2O13o

# ─── SALESFORCE AGENTFORCE (Coach Room — optional) ───────────────────────
# Used by the local Node app's /coach page to talk to a "headless" Agentforce
# Employee Agent (Internal Copilot). Uses JWT Bearer so each session runs as
# a real Salesforce user — required by the AgentforceEmployeeAgent type.
# If any of these are unset, /coach falls back to a lock screen.
#
# Instance URL of the org hosting the agent (no trailing slash).
#   e.g. https://mycompany.my.salesforce.com
SF_INSTANCE_URL=
# Consumer Key of the Connected App (with JWT Bearer enabled + Agentforce API scope).
SF_CLIENT_ID=
# Agentforce agent id (18-char Bot / Einstein Agent id).
SF_AGENT_ID=
# Salesforce username to run sessions as (must be pre-authorised in the Connected App).
SF_DEFAULT_USERNAME=
# Token endpoint audience — defaults to https://login.salesforce.com (use
# https://test.salesforce.com for sandbox orgs).
# SF_AUDIENCE=https://login.salesforce.com

# Path to the RSA private key used to sign JWT assertions (relative to project root).
# Generate: openssl genrsa -out server.key 2048
#           openssl req -new -x509 -key server.key -out server.crt -days 365
# Upload server.crt as a "Use Digital Signature" cert in the Connected App.
# server.key and server.crt are gitignored — never commit them.
SF_PRIVATE_KEY_PATH=server.key
# Alternatively, paste the PEM string inline (newlines as \n):
# SF_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...

# ─── NODE SERVER ─────────────────────────────────────────────────────────
PORT=3000
