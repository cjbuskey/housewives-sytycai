# ─── GCP AUTHENTICATION ──────────────────────────────────────────────────
# Pick ONE of the two options below.

# Option A (recommended for local dev): point to a service account key FILE.
# Download the JSON key from GCP Console → IAM → Service Accounts → Keys,
# save it somewhere outside the repo, and put the absolute path here.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Option B (required for Heroku): paste the JSON inline on ONE line.
# On Heroku you can't upload a file, so use: heroku config:set GOOGLE_CLOUD_CREDENTIALS="$(cat key.json)"
# If you use this locally, wrap in single quotes and keep it on one line.
# GOOGLE_CLOUD_CREDENTIALS='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}'

# ─── GCP PROJECT ─────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# ─── GCS BUCKETS ─────────────────────────────────────────────────────────
GCS_RAW_BUCKET=sytycai-video-transcripts
GCS_ENRICHED_BUCKET=sytycai-video-transcripts-enriched

# ─── SERVER ──────────────────────────────────────────────────────────────
PORT=3000
