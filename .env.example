# ─── GCP AUTHENTICATION ──────────────────────────────────────────────────
# Used by both the local Node.js ingestion app and local Cloud Function testing.
# Download a service account key JSON from GCP Console → IAM → Service Accounts
# → Keys → Add Key → Create New (JSON). Set the absolute path here.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# ─── GCP PROJECT ─────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# ─── GCS BUCKETS ─────────────────────────────────────────────────────────
# Used by the Node.js app (raw only) and the Cloud Function (reads raw, writes enriched).
GCS_RAW_BUCKET=sytycai-video-transcripts
GCS_ENRICHED_BUCKET=sytycai-video-transcripts-enriched

# ─── CLOUD FUNCTION — CLAUDE API ─────────────────────────────────────────
# Required when running the Python enrichment function locally via functions-framework.
# In deployed production, this is sourced from GCP Secret Manager — not from .env.
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── ELEVENLABS (Playback Room) ──────────────────────────────────────────
# Used by the local Node.js app's /playback page to read confessionals aloud.
# Sign up at elevenlabs.io → Profile → API key.
ELEVENLABS_API_KEY=sk_...
# Voice ID — defaults to "Matilda" (theatrical female voice). Browse voices
# at elevenlabs.io/voice-library to audition alternatives.
ELEVENLABS_VOICE_ID=XrExE9yKIg1WjnnlVkGX

# ─── SALESFORCE AGENTFORCE (Coach Room — optional) ───────────────────────
# Used by the local Node app's /coach page to talk to a "headless" Agentforce
# agent. If any of these are unset, /coach falls back to a link pointing at
# the Salesforce-hosted chat UI.
#
# Instance URL of the org hosting the agent (no trailing slash).
#   e.g. https://mycompany.my.salesforce.com
SF_INSTANCE_URL=
# Connected App credentials (client_credentials OAuth flow).
SF_CLIENT_ID=
SF_CLIENT_SECRET=
# Agentforce agent id (a.k.a. "Bot" / Einstein Agent 18-char id).
SF_AGENT_ID=

# ─── NODE SERVER ─────────────────────────────────────────────────────────
PORT=3000
